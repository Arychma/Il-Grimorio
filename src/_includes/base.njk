<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | Il Grimorio</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=IM+Fell+English:ital@0;1&family=Share+Tech+Mono&display=swap" rel="stylesheet">

  <style>
    /* ── VARIABILI ──────────────────────────────────────────── */
    :root {
      --parchment:      #f2e8d5;
      --parchment-dark: #e0d0b0;
      --ink:            #1a1209;
      --ink-faded:      #4a3728;
      --red:            #8b1a1a;
      --gold:           #c8922a;
      --gold-light:     #e8b84b;
      --dark-bg:        #12090a;
      --sidebar-w:      260px;
      --header-h:       56px;  /* altezza header mobile */

      --font-title:  'Cinzel', serif;
      --font-body:   'IM Fell English', serif;
      --font-mono:   'Share Tech Mono', monospace;
    }

    /* ── RESET ──────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ── BASE ───────────────────────────────────────────────── */
    html { font-size: 17px; }

    body {
      font-family: var(--font-body);
      background-color: var(--dark-bg);
      color: var(--ink);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ══════════════════════════════════════════════════════════
       HEADER MOBILE (hamburger)
    ══════════════════════════════════════════════════════════ */
    .mobile-header {
      display: none;
      position: fixed;
      top: 0; left: 0; right: 0;
      height: var(--header-h);
      background: var(--dark-bg);
      border-bottom: 1px solid var(--gold);
      z-index: 200;
      align-items: center;
      justify-content: space-between;
      padding: 0 1rem;
    }

    .mobile-header-title {
      font-family: var(--font-title);
      color: var(--gold-light);
      font-size: 1rem;
      letter-spacing: 0.1em;
    }

    .hamburger {
      background: none;
      border: none;
      cursor: pointer;
      display: flex;
      flex-direction: column;
      gap: 5px;
      padding: 4px;
    }

    .hamburger span {
      display: block;
      width: 24px;
      height: 2px;
      background: var(--gold);
      transition: all 0.3s ease;
    }

    /* Stato aperto */
    .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    /* Overlay scuro quando sidebar è aperta su mobile */
    .sidebar-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.6);
      z-index: 150;
    }
    .sidebar-overlay.active { display: block; }

    /* ══════════════════════════════════════════════════════════
       LAYOUT PRINCIPALE
    ══════════════════════════════════════════════════════════ */
    .site-wrapper {
      display: flex;
      flex: 1;
    }

    /* ══════════════════════════════════════════════════════════
       SIDEBAR
    ══════════════════════════════════════════════════════════ */
    .sidebar {
      width: var(--sidebar-w);
      min-height: 100vh;
      background: var(--dark-bg);
      border-right: 1px solid var(--gold);
      display: flex;
      flex-direction: column;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
      flex-shrink: 0;
      transition: transform 0.3s ease;
      scrollbar-width: thin;
      scrollbar-color: var(--gold) transparent;
    }

    .sidebar-title {
      padding: 1.5rem 1rem 1rem;
      border-bottom: 1px solid var(--gold);
      text-align: center;
    }

    .sidebar-title .label {
      display: block;
      font-family: var(--font-mono);
      color: var(--gold);
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      margin-bottom: 0.4rem;
    }

    .sidebar-title .name {
      font-family: var(--font-title);
      color: var(--gold-light);
      font-size: 1.1rem;
      letter-spacing: 0.08em;
    }

    /* Sezioni nav */
    .nav-section {
      padding: 0.75rem 0;
      border-bottom: 1px solid rgba(200,146,42,0.2);
    }

    .nav-section-label {
      font-family: var(--font-mono);
      color: var(--gold);
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 0 1rem 0.4rem;
      display: block;
    }

    .nav-section ul { list-style: none; }

    .nav-section ul li a {
      display: block;
      padding: 0.35rem 1rem 0.35rem 1.2rem;
      font-family: var(--font-body);
      color: var(--parchment-dark);
      text-decoration: none;
      font-size: 0.92rem;
      transition: color 0.2s, background 0.2s;
      border-left: 2px solid transparent;
    }

    .nav-section ul li a:hover,
    .nav-section ul li a.active {
      color: var(--gold-light);
      border-left-color: var(--gold);
      background: rgba(200,146,42,0.08);
    }

    /* Sottomenu (sistemi) */
    .nav-subsection { padding-left: 0.8rem; }

    .nav-subsection-label {
      font-family: var(--font-mono);
      color: var(--ink-faded);
      font-size: 0.58rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 0.4rem 1rem 0.2rem;
      display: block;
    }

    .sidebar-stamp {
      margin-top: auto;
      padding: 1rem;
      font-family: var(--font-mono);
      color: var(--ink-faded);
      font-size: 0.6rem;
      letter-spacing: 0.1em;
      text-align: center;
      border-top: 1px solid rgba(200,146,42,0.2);
    }

    /* ══════════════════════════════════════════════════════════
       CONTENUTO PRINCIPALE
    ══════════════════════════════════════════════════════════ */
    .main-content {
      flex: 1;
      background: var(--parchment);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .page-inner {
      max-width: 860px;
      margin: 0 auto;
      padding: 2.5rem 2rem 4rem;
      flex: 1;
    }

    /* Breadcrumb */
    .breadcrumb {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      color: var(--ink-faded);
      letter-spacing: 0.1em;
      margin-bottom: 1.5rem;
    }

    .breadcrumb a {
      color: var(--red);
      text-decoration: none;
    }

    .breadcrumb a:hover { text-decoration: underline; }

    /* Titoli */
    h1 {
      font-family: var(--font-title);
      color: var(--red);
      font-size: 2rem;
      border-bottom: 2px solid var(--gold);
      padding-bottom: 0.5rem;
      margin-bottom: 1.5rem;
    }

    h2 {
      font-family: var(--font-title);
      color: var(--ink);
      font-size: 1.3rem;
      margin: 2rem 0 0.75rem;
      padding-bottom: 0.3rem;
      border-bottom: 1px solid var(--parchment-dark);
    }

    h3 {
      font-family: var(--font-title);
      color: var(--ink-faded);
      font-size: 1rem;
      margin: 1.5rem 0 0.5rem;
    }

    p { line-height: 1.75; margin-bottom: 1rem; }

    a { color: var(--red); }
    a:hover { color: var(--gold); }

    ul, ol { padding-left: 1.5rem; margin-bottom: 1rem; }
    li { line-height: 1.7; margin-bottom: 0.25rem; }

    em { font-style: italic; }
    strong { font-weight: bold; color: var(--ink); }

    blockquote {
      border-left: 3px solid var(--gold);
      padding: 0.5rem 1rem;
      margin: 1rem 0;
      background: rgba(200,146,42,0.08);
      font-style: italic;
      color: var(--ink-faded);
    }

    code {
      font-family: var(--font-mono);
      background: var(--parchment-dark);
      padding: 0.1em 0.4em;
      border-radius: 3px;
      font-size: 0.85em;
    }

    hr {
      border: none;
      border-top: 1px solid var(--parchment-dark);
      margin: 2rem 0;
    }

    img {
      max-width: 100%;
      border-radius: 4px;
    }

    /* ── CARD GRIGLIA ───────────────────────────────────────── */
    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1rem;
      margin: 1.5rem 0;
    }

    .card {
      display: block;
      background: white;
      border: 1px solid var(--parchment-dark);
      border-top: 3px solid var(--gold);
      padding: 1.2rem;
      text-decoration: none;
      color: var(--ink);
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .card:hover {
      transform: translateY(-3px);
      box-shadow: 0 6px 20px rgba(0,0,0,0.12);
      color: var(--ink);
    }

    .card h3 {
      font-family: var(--font-title);
      color: var(--red);
      margin: 0 0 0.4rem;
      font-size: 1rem;
    }

    .card p {
      font-size: 0.88rem;
      color: var(--ink-faded);
      margin: 0;
      line-height: 1.5;
    }

    /* ── TAG ────────────────────────────────────────────────── */
    .tag {
      display: inline-block;
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.1em;
      padding: 0.2em 0.6em;
      border: 1px solid var(--gold);
      color: var(--gold);
      border-radius: 2px;
      margin: 0.2em;
    }

    .tag.red   { border-color: var(--red);  color: var(--red); }
    .tag.faded { border-color: var(--ink-faded); color: var(--ink-faded); }

    /* ── LISTA VOCI (sessioni, regole, ecc.) ────────────────── */
    .entry-list { list-style: none; padding: 0; }

    .entry-list li {
      border-bottom: 1px solid var(--parchment-dark);
      padding: 0.75rem 0;
    }

    .entry-list li:last-child { border-bottom: none; }

    .entry-list a {
      font-family: var(--font-title);
      font-size: 1rem;
      text-decoration: none;
      color: var(--red);
    }

    .entry-list a:hover { color: var(--gold); }

    .entry-meta {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      color: var(--ink-faded);
      margin-top: 0.2rem;
    }

    /* ── DOWNLOAD BOX ───────────────────────────────────────── */
    .download-box {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem;
      border: 1px solid var(--parchment-dark);
      background: white;
      text-decoration: none;
      color: var(--ink);
      margin-bottom: 0.75rem;
      transition: border-color 0.2s;
    }

    .download-box:hover { border-color: var(--gold); color: var(--ink); }

    .dl-icon { font-size: 1.8rem; }

    .dl-info strong {
      display: block;
      font-family: var(--font-title);
      font-size: 0.95rem;
      color: var(--red);
    }

    .dl-info span {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      color: var(--ink-faded);
    }

    /* ══════════════════════════════════════════════════════════
       RESPONSIVE — MOBILE
    ══════════════════════════════════════════════════════════ */
    @media (max-width: 768px) {

      /* Mostra header mobile */
      .mobile-header { display: flex; }

      /* Il contenuto scende sotto l'header */
      .site-wrapper { padding-top: var(--header-h); }

      /* Sidebar si nasconde fuori schermo */
      .sidebar {
        position: fixed;
        top: var(--header-h);
        left: 0;
        height: calc(100vh - var(--header-h));
        z-index: 160;
        transform: translateX(-100%);
        width: min(var(--sidebar-w), 85vw);
      }

      /* Quando il menu è aperto */
      .sidebar.open { transform: translateX(0); }

      /* Padding ridotto */
      .page-inner { padding: 1.5rem 1rem 3rem; }

      h1 { font-size: 1.5rem; }
      h2 { font-size: 1.1rem; }

      .card-grid { grid-template-columns: 1fr; }
    }

    @media (min-width: 769px) {
      /* Desktop: layout sidebar + content affiancati */
      .site-wrapper { flex-direction: row; }
    }

  </style>
</head>
<body>

  <!-- ── OVERLAY mobile ────────────────────────────────────── -->
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <!-- ── HEADER MOBILE ─────────────────────────────────────── -->
  <header class="mobile-header">
    <span class="mobile-header-title">✦ Il Grimorio ✦</span>
    <button class="hamburger" id="hamburger" aria-label="Apri menu">
      <span></span><span></span><span></span>
    </button>
  </header>

  <div class="site-wrapper">

    <!-- ── SIDEBAR ─────────────────────────────────────────── -->
    <aside class="sidebar" id="sidebar">

      <div class="sidebar-title">
        <span class="label">✦ IL GRIMORIO ✦</span>
        <span class="name">{{ siteName or "Il Grimorio" }}</span>
      </div>

      <!-- Home -->
      <nav class="nav-section">
        <ul>
          <li><a href="/">🏠 Home</a></li>
        </ul>
      </nav>

      <!-- Sistemi di gioco -->
      <nav class="nav-section">
        <span class="nav-section-label">Sistemi di Gioco</span>

        <div class="nav-subsection">
          <span class="nav-subsection-label">D&D 5.5e</span>
          <ul>
            <li><a href="/sistemi/dnd55e/">Panoramica</a></li>
            <li><a href="/sistemi/dnd55e/guida/">📖 Guida</a></li>
            <li><a href="/sistemi/dnd55e/avventure/">⚔ Avventure</a></li>
            <li><a href="/sistemi/dnd55e/archivio/personaggi/">👤 Personaggi</a></li>
            <li><a href="/sistemi/dnd55e/archivio/luoghi/">📍 Luoghi</a></li>
            <li><a href="/sistemi/dnd55e/archivio/regole/">📜 Regole</a></li>
            <li><a href="/sistemi/dnd55e/archivio/oggetti/">💎 Oggetti</a></li>
          </ul>
        </div>

        <div class="nav-subsection">
          <span class="nav-subsection-label">GURPS</span>
          <ul>
            <li><a href="/sistemi/gurps/">Panoramica</a></li>
            <li><a href="/sistemi/gurps/guida/">📖 Guida</a></li>
            <li><a href="/sistemi/gurps/avventure/">⚔ Avventure</a></li>
            <li><a href="/sistemi/gurps/archivio/personaggi/">👤 Personaggi</a></li>
            <li><a href="/sistemi/gurps/archivio/luoghi/">📍 Luoghi</a></li>
            <li><a href="/sistemi/gurps/archivio/regole/">📜 Regole</a></li>
            <li><a href="/sistemi/gurps/archivio/oggetti/">💎 Oggetti</a></li>
          </ul>
        </div>
      </nav>

      <!-- Ambientazioni -->
      <nav class="nav-section">
        <span class="nav-section-label">Ambientazioni</span>
        <ul>
          <li><a href="/ambientazioni/">Tutte le ambientazioni</a></li>
          <li><a href="/ambientazioni/forgotten-realms/">🌍 Forgotten Realms</a></li>
          <li><a href="/ambientazioni/khaesil/">🌍 Khaesil</a></li>
        </ul>
      </nav>

      <!-- Comunicazioni -->
      <nav class="nav-section">
        <span class="nav-section-label">Comunicazioni</span>
        <ul>
          <li><a href="/comunicazioni/blog/">📝 Blog</a></li>
          <li><a href="/comunicazioni/newsletter/">📨 Newsletter</a></li>
          <li><a href="/comunicazioni/downloads/">📥 Download</a></li>
        </ul>
      </nav>

      <!-- Jolly -->
      <nav class="nav-section">
        <ul>
          <li><a href="/jolly/">🃏 Jolly</a></li>
        </ul>
      </nav>

      <div class="sidebar-stamp">
        {% if page.date %}
          ✦ Aggiornato: {{ page.date | readableDate }} ✦
        {% else %}
          ✦ Il Grimorio ✦
        {% endif %}
      </div>

    </aside>

    <!-- ── CONTENUTO ───────────────────────────────────────── -->
    <main class="main-content">
      <div class="page-inner">

        {% if breadcrumb %}
          <div class="breadcrumb">
            <a href="/">Home</a>
            {% if breadcrumb2 %} › <a href="{{ breadcrumb2url }}">{{ breadcrumb2 }}</a>{% endif %}
            › {{ breadcrumb }}
          </div>
        {% endif %}

        {{ content | safe }}

      </div>
    </main>

  </div><!-- /site-wrapper -->

  <!-- ── PASSWORD OVERLAY ───────────────────────────────────── -->
  <div id="pw-overlay" style="
    display:none; position:fixed; inset:0; z-index:999;
    background:#12090a; align-items:center; justify-content:center;
    flex-direction:column; gap:1.2rem; font-family:'Cinzel',serif;">

    <h2 style="color:#e8b84b; font-size:1.4rem; letter-spacing:0.1em;">⚔ Il Grimorio ⚔</h2>
    <p style="color:#c8922a; font-family:'IM Fell English',serif; font-style:italic;">Pronuncia la parola, avventuriero.</p>

    <input id="pw-input" type="password" placeholder="Password"
      style="padding:0.6rem 1rem; background:#1e1010; border:1px solid #c8922a;
             color:#f2e8d5; font-family:'Share Tech Mono',monospace; font-size:1rem;
             outline:none; width:220px; text-align:center;"
      onkeydown="if(event.key==='Enter') checkPw()">

    <button onclick="checkPw()"
      style="padding:0.5rem 2rem; background:none; border:1px solid #c8922a;
             color:#c8922a; font-family:'Cinzel',serif; font-size:0.85rem;
             letter-spacing:0.15em; cursor:pointer;">ENTRA</button>

    <p id="pw-error" style="color:#8b1a1a; font-family:'Share Tech Mono',monospace;
       font-size:0.75rem; min-height:1em;"></p>
  </div>

  <script>
    // ── PASSWORD ──────────────────────────────────────────────
    const SITE_PASSWORD = "Mellon";
    const STORAGE_KEY   = "grimorio_auth";

    function checkPw() {
      const val = document.getElementById("pw-input").value;
      if (val === SITE_PASSWORD) {
        sessionStorage.setItem(STORAGE_KEY, "1");
        document.getElementById("pw-overlay").style.display = "none";
      } else {
        document.getElementById("pw-error").textContent = "Password errata. Riprova.";
        document.getElementById("pw-input").value = "";
      }
    }

    (function() {
      if (!sessionStorage.getItem(STORAGE_KEY)) {
        const ov = document.getElementById("pw-overlay");
        ov.style.display = "flex";
        setTimeout(() => document.getElementById("pw-input").focus(), 100);
      }
    })();

    // ── HAMBURGER MENU ────────────────────────────────────────
    const hamburger = document.getElementById("hamburger");
    const sidebar   = document.getElementById("sidebar");
    const overlay   = document.getElementById("sidebarOverlay");

    function toggleSidebar(open) {
      sidebar.classList.toggle("open", open);
      hamburger.classList.toggle("open", open);
      overlay.classList.toggle("active", open);
      document.body.style.overflow = open ? "hidden" : "";
    }

    hamburger.addEventListener("click", () => toggleSidebar(!sidebar.classList.contains("open")));
    overlay.addEventListener("click", () => toggleSidebar(false));

    // Chiudi sidebar su navigazione (mobile)
    sidebar.querySelectorAll("a").forEach(link => {
      link.addEventListener("click", () => {
        if (window.innerWidth <= 768) toggleSidebar(false);
      });
    });

    // Evidenzia link attivo
    const current = window.location.pathname;
    document.querySelectorAll(".sidebar a").forEach(a => {
      if (a.getAttribute("href") === current) a.classList.add("active");
    });
  </script>

</body>
</html>
