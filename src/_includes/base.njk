  </div>

  <!-- ── PASSWORD OVERLAY ───────────────────────────────────── -->
  <div id="pw-overlay" style="
    display:none; position:fixed; inset:0; z-index:999;
    background:#12090a; align-items:center; justify-content:center;
    flex-direction:column; gap:1.2rem; font-family:'Cinzel',serif;">

    <h2 style="color:#e8b84b; font-size:1.4rem; letter-spacing:0.1em;">⚔ Il Grimorio ⚔</h2>
    <p style="color:#c8922a; font-family:'IM Fell English',serif; font-style:italic;">Pronuncia la parola, avventuriero.</p>

    <input id="pw-input" type="password" placeholder="Password"
      style="padding:0.6rem 1rem; background:#1e1010; border:1px solid #c8922a;
             color:#f2e8d5; font-family:'Share Tech Mono',monospace; font-size:1rem;
             outline:none; width:220px; text-align:center;"
      onkeydown="if(event.key==='Enter') checkPw()">

    <button onclick="checkPw()"
      style="padding:0.5rem 2rem; background:none; border:1px solid #c8922a;
             color:#c8922a; font-family:'Cinzel',serif; font-size:0.85rem;
             letter-spacing:0.15em; cursor:pointer;">ENTRA</button>

    <p id="pw-error" style="color:#8b1a1a; font-family:'Share Tech Mono',monospace;
       font-size:0.75rem; min-height:1em;"></p>
  </div>

  <script src="/pagefind/pagefind-ui.js"></script>
  <script>
    // ── PASSWORD ──────────────────────────────────────────────
    const SITE_PASSWORD = "Mellon";
    const STORAGE_KEY   = "grimorio_auth";

    function checkPw() {
      const val = document.getElementById("pw-input").value;
      if (val === SITE_PASSWORD) {
        sessionStorage.setItem(STORAGE_KEY, "1");
        document.getElementById("pw-overlay").style.display = "none";
      } else {
        document.getElementById("pw-error").textContent = "Password errata. Riprova.";
        document.getElementById("pw-input").value = "";
      }
    }

    (function() {
      if (!sessionStorage.getItem(STORAGE_KEY)) {
        const ov = document.getElementById("pw-overlay");
        ov.style.display = "flex";
        setTimeout(() => document.getElementById("pw-input").focus(), 100);
      }
    })();

    // ── HAMBURGER MENU ────────────────────────────────────────
    const hamburger = document.getElementById("hamburger");
    const sidebar   = document.getElementById("sidebar");
    const overlay   = document.getElementById("sidebarOverlay");

    function toggleSidebar(open) {
      sidebar.classList.toggle("open", open);
      hamburger.classList.toggle("open", open);
      overlay.classList.toggle("active", open);
      document.body.style.overflow = open ? "hidden" : "";
    }

    hamburger.addEventListener("click", () => toggleSidebar(!sidebar.classList.contains("open")));
    overlay.addEventListener("click", () => toggleSidebar(false));

    sidebar.querySelectorAll("a").forEach(link => {
      link.addEventListener("click", () => {
        if (window.innerWidth <= 768) toggleSidebar(false);
      });
    });

    // ── LINK ATTIVO ───────────────────────────────────────────
    const current = window.location.pathname;
    document.querySelectorAll(".sidebar a").forEach(a => {
      if (a.getAttribute("href") === current) a.classList.add("active");
    });

    // ── TAB ───────────────────────────────────────────────────
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const group = btn.closest('.tab-group') || btn.parentElement.parentElement;
        group.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        group.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
        btn.classList.add('active');
        group.querySelector('#' + btn.dataset.tab).classList.add('active');
      });
    });

    // ── PAGEFIND ──────────────────────────────────────────────
    window.addEventListener('DOMContentLoaded', () => {
      new PagefindUI({ element: "#search", showImages: false });
    });
  </script>

</body>
</html>
