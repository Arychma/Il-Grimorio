<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <div class="theme-switch-container">
      <button id="theme-toggle" aria-label="Cambia Tema">
        <span class="icon-sun">☀️</span>
        <span class="icon-moon">🌙</span>
      </button>
    </div>
  </div>

  <div class="sidebar-title">
    <span class="label">ARCHIVIO</span>
    <span class="name">{{ metadata.title }}</span>
  </div>

  <nav class="sidebar-nav">
  
  <div class="nav-section">
    <span class="nav-section-label">Personaggi</span>
    <ul class="nav-list">
      {% for p in collections.personaggi %}
        <li class="nav-item">
          <a href="{{ p.url }}" class="nav-link {% if p.url == page.url %}active{% endif %}">
            {{ p.data.title }}
          </a>
        </li>
      {% endfor %}
    </ul>
  </div>

  <div class="nav-section">
    <span class="nav-section-label">Luoghi</span>
    <ul class="nav-list">
      {% for l in collections.luoghi %}
        <li class="nav-item">
          <a href="{{ l.url }}" class="nav-link {% if l.url == page.url %}active{% endif %}">
            {{ l.data.title }}
          </a>
        </li>
      {% endfor %}
    </ul>
  </div>

</nav>

  <div class="sidebar-stamp">
    2026 - Il Grimorio
  </div>
</aside>