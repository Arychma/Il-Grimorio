<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <div class="theme-switch-container">
      <button id="theme-toggle" aria-label="Cambia Tema">
        <span class="icon-sun">☀️</span>
        <span class="icon-moon">🌙</span>
      </button>
    </div>
  </div>

  <div class="sidebar-title">
    <span class="label">ARCHIVIO</span>
    <span class="name">{{ metadata.title }}</span>
  </div>

  <nav class="nav-section">
    <span class="nav-section-label">NAVIGAZIONE</span>
    {# Genera la lista con le classi che il tuo CSS aspetta #}
    {{ collections.all | eleventyNavigation | eleventyNavigationToHtml({
        listClass: "nav-list",
        listItemClass: "nav-item",
        activeListItemClass: "active",
        anchorClass: "nav-link"
    }) | safe }}
  </nav>

  <div class="sidebar-stamp">
    2026 - Il Grimorio
  </div>
</aside>