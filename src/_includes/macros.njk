{% macro cardGrid(collectionName, tagFilter=null) %}
  {# Recupero sicuro: se la collezione non esiste, usa una lista vuota #}
  {% set allItems = collections[collectionName] or [] %}
  
  {# Filtro opzionale per tag (utile per le ambientazioni) #}
  {% if tagFilter %}
    {% set items = allItems | filterByTag(tagFilter) %}
  {% else %}
    {% set items = allItems %}
  {% endif %}

  <div class="card-grid">
    {% for item in items %}
      <article class="card">
        <a href="{{ item.url }}">
          <div class="card-body">
            {# Gestione Titolo: supporta Markdown e Navigation #}
            <h3 class="card-title">
              {{ item.data.title or item.title or "Senza Titolo" }}
            </h3>
            
            {# Estrazione Dati: normalizza l'accesso al frontmatter #}
            {% set info = item.data if item.data else item %}
            
            <div class="card-meta">
              {% if info.type %}
                <span class="tag-type">{{ info.type }}</span>
              {% endif %}
              
              {% if info.region %}
                <span class="tag-region">{{ info.region }}</span>
              {% endif %}

              {% if info.status %}
                <span class="status {{ info.status | lower }}">{{ info.status }}</span>
              {% endif %}
            </div>

            {% if info.description %}
              <p class="card-text">{{ info.description }}</p>
            {% endif %}
          </div>
        </a>
      </article>
    {% else %}
      {# Questo appare solo se la collezione è davvero vuota #}
      <p class="debug-msg">Nessun elemento presente in <em>{{ collectionName }}</em>.</p>
    {% endfor %}
  </div>
{% endmacro %}