{% macro cardGrid(collectionName, tagFilter=null) %}
  {# Usiamo il filtro filterByTag che abbiamo definito in .eleventy.js #}
  {% set items = collections[collectionName] | filterByTag(tagFilter) %}

  <div class="card-grid">
    {% for item in items %}
      <article class="card">
        <a href="{{ item.url | url }}">
          <div class="card-body">
            <h3 class="card-title">{{ item.data.title }}</h3>
            
            <div class="card-meta">
              {% if item.data.type %}<span class="tag-type">{{ item.data.type }}</span>{% endif %}
              {% if item.data.region %}<span class="tag-region">{{ item.data.region }}</span>{% endif %}
              
              {% if item.data.status %}
                <span class="status-badge {{ item.data.status | lower | replace(' ', '-') }}">
                  {{ item.data.status }}
                </span>
              {% endif %}
            </div>

            {% if item.data.description %}
              <p class="card-text">{{ item.data.description }}</p>
            {% endif %}
          </div>
        </a>
      </article>
    {% else %}
      <p class="no-content">Nessuna voce trovata in questa categoria.</p>
    {% endfor %}
  </div>
{% endmacro %}