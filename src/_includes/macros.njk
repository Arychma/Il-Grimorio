{% macro cardGrid(collectionName, tagFilter=null) %}
  {# 1. Recupero della collezione con le parentesi quadre per gestire i trattini #}
  {% set allItems = collections[collectionName] or [] %}
  
  {# 2. Applicazione del filtro tag (se richiesto) #}
  {% if tagFilter %}
    {% set items = allItems | filterByTag(tagFilter) %}
  {% else %}
    {% set items = allItems %}
  {% endif %}

  <div class="card-grid">
    {% for item in items %}
      <article class="card">
        <a href="{{ item.url }}">
          <div class="card-body">
            {# 3. Gestione flessibile del titolo (cerca in diverse posizioni) #}
            <h3 class="card-title">
              {{ item.data.title or item.title or "Senza Titolo" }}
            </h3>
            
            <div class="card-meta">
              {# 4. Normalizzazione dei dati per accedere a 'type' o 'region' #}
              {% set info = item.data if item.data else item %}
              
              {% if info.type %}
                <span class="tag-type">{{ info.type }}</span>
              {% endif %}
              
              {% if info.region %}
                <span class="tag-region">{{ info.region }}</span>
              {% endif %}
            </div>

            {% if info.description %}
              <p class="card-text">{{ info.description }}</p>
            {% endif %}
          </div>
        </a>
      </article>
    {% else %}
      {# 5. Messaggio di debug migliorato #}
      <div class="debug-error" style="padding: 20px; border: 1px dashed #ccc; color: #666;">
        <strong>Nota:</strong> Nessun elemento trovato nella collezione 
        <code>"{{ collectionName }}"</code> 
        {% if tagFilter %}con il tag <code>"{{ tagFilter }}"</code>{% endif %}.
      </div>
    {% endfor %}
  </div>
{% endmacro %}