{% macro cardGrid(collections, parentKey, filters={}, sort="default", hide=[]) %}
  {% set navItems = collections.all | eleventyNavigation(parentKey) %}
  {% set finalItems = [] %}

  {% for navItem in navItems %}
    {% for page in collections.all %}
      {% if page.url == navItem.url %}
        {% set include = true %}
        {% if filters.tag and page.data.tags %}
          {% if filters.tag not in page.data.tags %}
            {% set include = false %}
          {% endif %}
        {% endif %}
        {% if filters.type and page.data.type != filters.type %}
          {% set include = false %}
        {% endif %}
        {% if filters.status and page.data.status != filters.status %}
          {% set include = false %}
        {% endif %}
        {% if filters.setting and page.data.setting != filters.setting %}
          {% set include = false %}
        {% endif %}
        {% if include %}
          {% set finalItems = finalItems.concat([page]) %}
        {% endif %}
      {% endif %}
    {% endfor %}
  {% endfor %}

  {% if sort == "title" %}
    {% set finalItems = finalItems | sort(false, false, "data.title") %}
  {% elif sort == "date" %}
    {% set finalItems = finalItems | sort(true, false, "data.date") %}
  {% endif %}

  <div class="card-grid">
    {% for item in finalItems %}
      <article class="card">
        <a href="{{ item.url }}">
          <h3 class="card-title">{{ item.data.title or "Senza Titolo" }}</h3>

          {% if item.data.role or item.data.type %}
            <p class="card-subtitle">{{ item.data.role or item.data.type }}</p>
          {% endif %}

          <div class="card-meta">

            {% if item.data.adventure and "adventure" not in hide %}
              <span class="card-tag">{{ item.data.adventure }}</span>
            {% endif %}

            {% if item.data.status and "status" not in hide %}
              <span class="card-status card-status--{{ item.data.status | lower | replace(' ', '-') }}">
                {{ item.data.status }}
              </span>
            {% endif %}

            {% if item.data.setting and "setting" not in hide %}
              <span class="card-tag">{{ item.data.setting }}</span>
            {% endif %}

            {% if item.data.date and "date" not in hide %}
              <span class="card-tag">{{ item.data.date | readableDate }}</span>
            {% endif %}

          </div>

          {% if item.data.description %}
            <p class="card-description">{{ item.data.description }}</p>
          {% endif %}

        </a>
      </article>
    {% else %}
      <p class="card-empty">Nessun elemento figlio di <em>{{ parentKey }}</em>.</p>
    {% endfor %}
  </div>

{% endmacro %}