{% macro cardGrid(collectionName, tagFilter=null) %}
  {# 1. Recuperiamo gli elementi #}
  {% set allItems = collections[collectionName] %}
  
  {# 2. Applichiamo il filtro solo se necessario #}
  {% if tagFilter %}
    {% set items = allItems | filterByTag(tagFilter) %}
  {% else %}
    {% set items = allItems %}
  {% endif %}

  <div class="card-grid">
    {% for item in items %}
      <article class="card">
        <a href="{{ item.url }}">
          <div class="card-body">
            <h3 class="card-title">{{ item.data.title or "Senza Titolo" }}</h3>
            
            <div class="card-meta">
              {% if item.data.type %}<span class="tag-type">{{ item.data.type }}</span>{% endif %}
              {% if item.data.region %}<span class="tag-region">{{ item.data.region }}</span>{% endif %}
            </div>

            {% if item.data.description %}
              <p class="card-text">{{ item.data.description }}</p>
            {% endif %}
          </div>
        </a>
      </article>
    {% else %}
      {# Se non vede nulla, ci aiuta a capire perché #}
      <div style="border: 1px dashed var(--red); padding: 10px; font-size: 0.8rem;">
        <strong>Debug:</strong> Nessun elemento trovato per la collezione <code>"{{ collectionName }}"</code> 
        {% if tagFilter %}con tag <code>"{{ tagFilter }}"</code>{% endif %}.
        <br>Verifica che la collezione esista in <code>.eleventy.js</code>.
      </div>
    {% endfor %}
  </div>
{% endmacro %}