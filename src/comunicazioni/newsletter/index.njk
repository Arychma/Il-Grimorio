<h1>Newsletter</h1>

<p><em>Comunicazioni inviate ai giocatori.</em></p>

{% if collections.newsletter and collections.newsletter.length %}
<ul class="entry-list">
{% for item in collections.newsletter %}
  <li>
    <a href="{{ item.url }}">{{ item.data.title }}</a>
    {% if item.data.date %}<div class="entry-meta">{{ item.data.date | readableDate }}{% if item.data.description %} — {{ item.data.description }}{% endif %}</div>{% endif %}
  </li>
{% endfor %}
</ul>
{% else %}
<p><em>Nessuna newsletter ancora presente.</em></p>
{% endif %}
